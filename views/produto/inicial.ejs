<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h4>
                <%= titulo %>
            </h4>
            <p class="mb-0">&raquo; Consulte todos os produtos do sistema</p>
        </div>
    </div>
    <div class="col-sm-6 p-md-0 justify-content-sm-end mt-2 mt-sm-0 d-flex">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Inicial</a></li>
            <li class="breadcrumb-item active"><a href="javascript:void(0)">Produtos</a></li>
        </ol>
    </div>
</div>
<!-- row -->

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <div class="basic-form">
                    <form>
                        <div class="form-row">
                            <div class="col-lg-10">
                                <input type="text" class="form-control" placeholder="Digite para pesquisar...">
                            </div>
                            <div class="col-lg-2 mt-2 mt-lg-0">
                                <button type="submit" class="btn btn-primary mb-2">Pesquisar</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-responsive-sm">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Nome</th>
                                <th>Preço</th>
                                <th>Ativo?</th>
                                <th>Criado em</th>
                                <th>Atualizado em</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% for( let index=0; index < produtos.length; index++ ) { %>
                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= produtos[index].nome %>
                                    </td>
                                    <td>
                                        <%= currencyFormat(produtos[index].preco) %>
                                    </td>

                                    <td>
                                        <% if (produtos[index].ativo) { %>
                                            <span class="badge badge-success">Sim</span>
                                            <% } else { %>
                                                <span class="badge badge-danger">Não</span>
                                                <% } %>

                                    </td>
                                    <td>
                                        <%= dateFormat(produtos[index].criadoEm) %>
                                    </td>
                                    <td>
                                        <%= dateFormat(produtos[index].atualizadoEm) %>
                                    </td>
                                    <td>
                                        <span>
                                            <a href="/produtos/<%= produtos[index].id %>/editar" class="mr-4" data-toggle="tooltip" data-placement="top" title="Editar">
                                                <i class="fa fa-pencil color-muted"></i>
                                            </a>
                                            <a href="/produtos/<%= produtos[index].id %>/excluir" data-toggle="tooltip" data-placement="top" title="Excluir">
                                                <i class="fa fa-close color-danger"></i>
                                            </a>
                                        </span>
                                    </td>

                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>