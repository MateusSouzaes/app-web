<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NestJs MVC</title>
</head>
<body>
    <h1><%= titulo %></h1>
    <h2>NestJs MVC + EJS <%= horaAgora %>.</h2>

    <ol>
        <% for (let index = 0; index <  listaPessoas.length; index++) {%>
            <li> [<%=(index + 1) %>] <%= listaPessoas[index].nome %> - <%= listaPessoas[index].email %></li>            
        <% } %>
    </ol>

    <table border: 1px solid #cbd5e1; border-collapse: collapse; " border="1"> 
    <thead>
        <tr bgcolor = "#CCCCCC">
            <th>Ordem</th>
            <th>Nome</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
        <% for (let index = 0; index <  listaPessoas.length; index++) {%>
            <tr>
                <td><%=(index + 1) %></td>
                <td><%= listaPessoas[index].nome %></td>
                <td><%= listaPessoas[index].email %></td>
            </tr>            
        <% } %>
    </tbody>

</table>
</body>


</html>